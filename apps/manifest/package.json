{
  "name": "@repo/manifest",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Yasin Çakmak <mishucon@pm.me> (https://github.com/mishuw/)",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "bun --watch ./index.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint --fix .",
    "start": "bun ./dist/index.js",
    "test:e2e": "bun playwright test",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,mjs,jsx,ts,mts,tsx}": "eslint --fix",
    "*": [
      "prettier --write --ignore-unknown",
      "cspell --no-progress --no-summary --no-must-find-files --unique"
    ]
  },
  "dependencies": {
    "@discordjs/opus": "0.10.0",
    "@discordjs/voice": "0.19.2",
    "@distube/spotify": "2.0.2",
    "@distube/yt-dlp": "2.0.1",
    "@repo/client": "workspace:*",
    "@repo/config": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/shared": "workspace:*",
    "discord.js": "^14.25.1",
    "distube": "5.2.3",
    "ffmpeg-static": "5.3.0",
    "opusscript": "0.1.1"
  },
  "devDependencies": {
    "@repo/client": "workspace:*",
    "@types/node": "24.9.2"
  }
}
