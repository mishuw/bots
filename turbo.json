{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },

    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },

    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },

    "lint": {
      "outputs": []
    },

    "lint:fix": {
      "cache": false
    },

    "type-check": {
      "outputs": []
    },

    "clean": {
      "cache": false
    },

    "db:check": {
      "cache": false
    },
    "db:generate": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false,
      "persistent": true
    },
    "db:reset": {
      "cache": false,
      "persistent": true
    },
    "db:seed": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  },
  "ui": "tui"
}
