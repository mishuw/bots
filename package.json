{
  "name": "wosski_pack",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Yasin Çakmak <mishucon@pm.me> (https://github.com/mishuw/)",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "build:apps": "turbo build --filter=./apps/*",
    "build:packages": "turbo build --filter=./packages/*",
    "check": "pnpm lint && pnpm type-check && pnpm format:check && pnpm check:knip && pnpm db:check",
    "check:knip": "pnpm knip",
    "clean": "turbo clean",
    "db:check": "pnpm db:check",
    "db:drop": "turbo db:drop",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:reset": "turbo db:reset",
    "db:studio": "turbo db:studio",
    "dev": "turbo dev",
    "dev:a": "___________DEVELOPMENT_______",
    "dev:apps": "turbo dev --filter=./apps/*",
    "dev:paranoia": "turbo dev --filter=@repo/paranoia",
    "format:check": "prettier --cache --check --ignore-path .gitignore --ignore-path .prettierignore .",
    "format:write": "prettier --cache --write --list-different --ignore-path .gitignore --ignore-path .prettierignore .",
    "preinstall": "npx --yes only-allow pnpm",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "start": "turbo start",
    "start:a": "___________PRODUCTION________",
    "start:apps": "turbo start --filter=./apps/*",
    "start:paranoia": "turbo start --filter=@repo/paranoia",
    "type-check": "tsc --noEmit",
    "typegen": "turbo typegen"
  },
  "devDependencies": {
    "@commitlint/cli": "20.1.0",
    "@commitlint/config-conventional": "20.0.0",
    "@nelsonlaidev/eslint-config": "2.3.3",
    "@nelsonlaidev/prettier-config": "0.1.0",
    "@nelsonlaidev/typescript-config": "1.0.0",
    "@playwright/test": "1.56.1",
    "@types/node": "24.9.2",
    "czg": "1.12.0",
    "eslint": "9.39.1",
    "jsdom": "27.0.1",
    "knip": "5.66.4",
    "lefthook": "2.0.2",
    "prettier": "3.6.2",
    "prettier-plugin-packagejson": "2.5.19",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "turbo": "2.5.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=24"
  }
}